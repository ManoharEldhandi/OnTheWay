# ===================================================================
# OnTheWay — environment variables (example)
# Copy to ".env" and adjust. NEVER commit a real ".env".
# In dev, required values have local fallbacks so the app runs without this file.
# In prod, database, JWT, CORS, and payment-provider values are mandatory.
# ===================================================================

# Active Spring profile: dev | test | prod | demo
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# --- Database (dev/prod) ---
DB_URL=jdbc:mysql://localhost:3306/onthewaydb?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=change-me

# --- JWT ---
# Use a long, random secret (>= 32 bytes) in production.
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=1209600000

# --- CORS (comma-separated allowlist of frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Security ---
AUTH_RATE_LIMIT=10

# --- ETA engine ---
ETA_SCHEDULER_ENABLED=true
ETA_AVERAGE_SPEED_KMPH=30
ETA_SAFETY_BUFFER_MINS=5

# --- Payments (provider: mock | stripe | razorpay) ---
PAYMENT_PROVIDER=mock
SWAGGER_ENABLED=false
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_API_KEY=
RAZORPAY_API_SECRET=

# --- Routing (the included provider is the keyless Haversine "mock" adapter) ---
ROUTE_PROVIDER=mock
