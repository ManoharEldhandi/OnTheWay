<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logging configuration. Each line includes the per-request correlation id (requestId)
  from the MDC, set by RequestCorrelationFilter, so all log lines for one request can be
  correlated. Falls back to "-" outside a request scope.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%X{requestId:--}] [%t] %-40.40logger{39} : %m%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
